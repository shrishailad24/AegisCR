# AegisCR Environment Variables Configuration Example
# Duplicate this file to '.env' and fill in your actual API keys

# Unsplash Search API Access Key
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Pexels Landscape API Key
PEXELS_API_KEY=your_pexels_api_key_here

# OpenWeatherMap API Key
WEATHER_API_KEY=your_weather_api_key_here

# Groq Explainable AI LLM API Key
GROQ_API_KEY=your_groq_api_key_here

# Path to Google Vision OCR JSON credentials file (if using Google Cloud Vision)
GOOGLE_APPLICATION_CREDENTIALS=credentials/google-vision-key.json

# Server port bind setting
PORT=8501
